# ============================================================
#  L!M Vario - .gitignore
# ============================================================

# Build PlatformIO (hors Nextcloud, mais par securite)
.pio/
C:/PioBuild/

# Dossiers archives / backups locaux
_Archive/
_Backup*/

# Ancien dossier UI (doublon de "L!M Vario UI")
UI/

# EEZ Studio cache
*.eez-project-ui-state

# Fichiers systeme
.DS_Store
Thumbs.db
desktop.ini

# Python cache
__pycache__/
*.pyc

# Binaires produits (trop lourds pour git)
*.bin
*.elf
*.hex
*.factory.bin

# Fichiers temporaires
*.tmp
*.bak
*.swp
