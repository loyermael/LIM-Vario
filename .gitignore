# ============================================================
#  L!M Vario - .gitignore
# ============================================================

# Build PlatformIO (hors Nextcloud, mais par securite)
.pio/
C:/PioBuild/

# Dossiers archives / backups locaux
_Archive/
_Backup*/

# Ancien dossier UI a la RACINE uniquement (doublon de "L!M Vario UI")
# (PAS "UI/" tout court : sur Windows ca ignorait aussi Firmware/src/ui !)
/UI/

# Marqueur de build EEZ
.eez-project-build

# EEZ Studio cache
*.eez-project-ui-state

# Fichiers systeme
.DS_Store
Thumbs.db
desktop.ini

# Python cache
__pycache__/
*.pyc

# Binaires produits (trop lourds pour git)
*.bin
*.elf
*.hex
*.factory.bin

# Fichiers temporaires
*.tmp
*.bak
*.swp

# EEZ Studio docker build cache
.docker-build-output/

# Modeles 3D fabricant (trop lourds, dispo chez Waveshare)
3D/ESP32-LCD*

# Fichiers lock Affinity
*~lock~

# Dossiers locaux non publies
/3D/
/GraphX/
